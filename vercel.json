{
  "rewrites": [
    {
      "source": "/api/revenue",
      "destination": "/api/index.py"
    }
  ],
  "headers": [
    {
      "source": "/api/index.py",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=60, stale-while-revalidate=120"
        }
      ]
    }
  ]
}
